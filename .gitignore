# Rust/Cargo build directory
/target/

# If using workspaces, ignore nested target folders too
**/target/

# Ignore build artifacts
*.rlib
*.dSYM/

# Generated by Cargo (lockfile is usually committed for apps, but keep it unignored by default)
# Cargo.lock

# IDEs and editors
.vscode/
.idea/
*.iml

# macOS
.DS_Store

# Vim
*.swp

# Emacs
*~

# Logs
*.log

# Node (if present)
node_modules/

# Misc
dist/
coverage/

# Temporary specification files (keep drafts out of the repo)
ORBIT_Especificacion_Tecnica.md
ORBIT_Technical_Specification.md
